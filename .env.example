# Remote Backend Connections
# Copy to .env and fill in credentials. The .env file is gitignored.

# Trino
TRINO_ENABLED=true
TRINO_HOST=trino.example.com
TRINO_PORT=443
TRINO_USER=
TRINO_PASSWORD=
TRINO_SSL=true

# DataHub
DATAHUB_ENABLED=true
DATAHUB_ENDPOINT=https://datahub.example.com/api/graphql
DATAHUB_TOKEN=

# S3 (or S3-compatible)
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Providers (set to datahub/trino when backends are configured)
SEMANTIC_PROVIDER=noop
QUERY_PROVIDER=noop

# Encryption key for connection credentials (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=
